{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "dart-mcp-server": {
      "type": "local",
      "command": [
        "dart",
        "mcp-server"
      ],
      "enabled": true,
      "environment": {}
    }
  },
  "lsp": {
    "dart-external": {
      "command": [
        "dart",
        "language-server"
      ],
      "extensions": [
        ".dart"
      ],
      "initialization": {}
    }
  },
  "provider": {
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (local)",
      "options": {
        "baseURL": "http://127.0.0.1:1234/v1"
      },
      "models": {
        "google/gemma-4n-e4b": {
          "name": "Gemma 4n-e4b (local)"
        }
      }
    }
  }
}
